# --- Root .gitignore for CityOrders Project ---

# Visual Studio / VS Code
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates
*.code-workspace

# Build artifacts
[Bb]in/
[Oo]bj/
dist/
build/
web-build/
.expo/

# Dependencies
node_modules/
jspm_packages/

# Environment files and secrets
.env
.env.local
.env.*.local
appsettings.Development.json
appsettings.Local.json

# Project-specific sensitive data
CityOrders.Api/uploads/
CityOrders.Api/wwwroot/uploads/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Mobile specific
ios/
android/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Miscellaneous
*.tsbuildinfo
.metro-health-check*
